# Copy to .env (gitignored). Used by pydantic-settings and docker compose.

DATABASE_URL=postgresql+asyncpg://duliu:duliu@localhost:5432/duliu
DULIU_RUNNER_WORK_DIR=/tmp/duliu-runner
JOB_POLL_SECONDS=1
CORS_ORIGINS=*

# Optional: LLM Session Agent (also configurable in Web → 设置)
OPENAI_API_KEY=

# Optional: LangGraph (docker-compose.m1.yml sets these by default)
DULIU_USE_LANGGRAPH=true
DULIU_LANGGRAPH_CHECKPOINT=postgres

# Optional: use isolate for C++ runs when `isolate` is on PATH (M11)
DULIU_USE_ISOLATE=false

# Optional: seed workspace crawler secrets on API startup if not already in DB (M11)
# Prefer Web 设置 for production; .env is convenient for local testing.
DULIU_CF_COOKIE=
DULIU_LUOGU_COOKIE=
DULIU_POLYGON_COOKIE=
